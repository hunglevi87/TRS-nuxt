# Supabase — Project URL and anon (public) key from your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App
BASE_URL=http://localhost:3000

# Stripe — use test keys (sk_test_... / pk_test_...) for local development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Resend — transactional email
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
SELLER_EMAIL=seller@yourdomain.com

# Stripe checkout redirect URLs
SUCCESS_URL=http://localhost:3000/success?session_id={CHECKOUT_SESSION_ID}
CANCEL_URL=http://localhost:3000/cancel

# OpenFang job runner
OPENFANG_RUNNER_TOKEN=
OPENFANG_AI_ENDPOINT=
OPENFANG_AI_API_KEY=
OPENFANG_AI_TIMEOUT_MS=15000

# eBay MCP integration
EBAY_MCP_BASE_URL=
EBAY_MCP_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=sandbox
EBAY_REDIRECT_URI=
EBAY_USER_REFRESH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CONTENT_LANGUAGE=en-US
EBAY_MCP_TIMEOUT_MS=15000

# Emma AI
EMMA_AI_ENDPOINT=
